variant: fcos
version: 1.5.0

ignition:
  config:
    merge:
      - local: bootstrap-in-place-for-live-iso.ign

passwd:
  users:
    - name: core
      password_hash: "$6$jamyHU6tcWovxP.e$rasKzY7tDn.LlazCF6Z4osY86aaXGEFOnkDSClPCw1B/DzPn2knv/kHCwncynti2r3k8MSLwcEsyEwqkDwZd8/"
      ssh_authorized_keys:
        - ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIN7zgvPt+AVZF06sA0jRY6MByNyytlGsMn6z+KMjjX7/ dkhater@redhat.com-sno
        - ssh-rsa  ravanelli@renatas-air.br.ibm.com

storage:
  files:
    - path: /etc/hostname
      mode: 0644
      overwrite: true
      contents:
        inline: vera-rubin.nvidia.local
    - path: /etc/NetworkManager/system-connections/enP13s20f0np0.nmconnection
      mode: 0600
      overwrite: true
      contents:
        inline: |
          [connection]
          id=enP13s20f0np0
          type=ethernet
          interface-name=enP13s20f0np0
          autoconnect=true

          [ipv4]
          method=manual
          addresses=10.78.214.40/27
          gateway=10.78.214.33
          dns=10.78.214.62;103.247.36.36

    - path: /etc/NetworkManager/dnsmasq.d/ocp-sno.conf
      mode: 0644
      overwrite: true
      contents:
        inline: |
          local=/vera-rubin.nvidia.local/
          address=/api.vera-rubin.nvidia.local/10.78.214.40
          address=/api-int.vera-rubin.nvidia.local/10.78.214.40
          address=/apps.vera-rubin.nvidia.local/10.78.214.40
          listen-address=127.0.0.1
          listen-address=10.78.214.40
          cache-size=1000
          server=10.78.214.62
          server=8.8.8.8

    - path: /etc/NetworkManager/conf.d/dnsmasq.conf
      mode: 0644
      overwrite: true
      contents:
        inline: |
          [main]
          dns=dnsmasq

    - path: /etc/ssh/sshd_config.d/01-password-auth.conf
      mode: 0644
      overwrite: true
      contents:
        inline: |
          PasswordAuthentication yes

systemd:
  units:
    - name: dnsmasq.service
      enabled: false
      mask: true
